{
  "cli": { "version": ">= 18.8.1" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "bundleIdentifier": "com.pnarielwala.choreo-cue.dev"
      },
      "android": {
        "package": "com.pnarielwala.choreocue.dev"
      }
    },
    "production": {
      "autoIncrement": true,
      "node": "22.11.0",
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "ios": {},
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json"
      }
    }
  }
}
