{
  "name": "choreo-cue",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "commit": "git add . && git commit",
    "start": "NODE_ENV=development expo start",
    "build:ios": "NODE_ENV=production expo build:ios",
    "build:android": "NODE_ENV=production expo build:android",
    "test": "jest --watch --coverage=false",
    "eject": "expo eject",
    "prepare": "husky install",
    "semantic-release": "semantic-release"
  },
  "dependencies": {
    "@react-native-community/slider": "3.0.3",
    "@react-navigation/native": "^6.0.0-next.9",
    "@react-navigation/stack": "^6.0.0-next.19",
    "axios": "0.21.1",
    "dripsy": "2.2.0",
    "expo": "42.0.3",
    "expo-auth-session": "~3.3.1",
    "expo-av": "~9.2.3",
    "expo-device": "~3.3.0",
    "expo-document-picker": "~9.2.4",
    "expo-file-system": "~11.1.3",
    "expo-keep-awake": "~9.2.0",
    "expo-linking": "~2.3.1",
    "expo-media-library": "~12.1.2",
    "expo-random": "~11.2.0",
    "expo-secure-store": "~10.2.0",
    "expo-status-bar": "~1.0.4",
    "format-duration": "^1.3.1",
    "react": "16.13.1",
    "react-dom": "16.13.1",
    "react-native": "https://github.com/expo/react-native/archive/sdk-42.0.0.tar.gz",
    "react-native-audio-recorder-player": "^2.6.2",
    "react-native-dotenv": "3.2.0",
    "react-native-elements": "^3.4.1",
    "react-native-gesture-handler": "~1.10.2",
    "react-native-loading-spinner-overlay": "2.0.0",
    "react-native-modal": "^11.10.0",
    "react-native-reanimated": "~2.2.0",
    "react-native-safe-area-context": "3.2.0",
    "react-native-screens": "~3.4.0",
    "react-native-slider": "^0.11.0",
    "react-native-text-ticker": "^1.12.0",
    "react-native-toast-message": "^1.4.9",
    "react-native-vector-icons": "8.1.0",
    "react-native-web": "~0.13.12",
    "react-query": "3.18.1",
    "rn-fetch-blob": "^0.12.0"
  },
  "devDependencies": {
    "@babel/core": "~7.9.0",
    "@babel/preset-typescript": "7.14.5",
    "@semantic-release/changelog": "5.0.1",
    "@semantic-release/exec": "5.0.0",
    "@semantic-release/git": "9.0.0",
    "@testing-library/jest-native": "4.0.2",
    "@testing-library/react-native": "7.2.0",
    "@types/faker": "5.5.8",
    "@types/format-duration": "^1.0.1",
    "@types/jest": "26.0.24",
    "@types/react": "~16.9.35",
    "@types/react-native": "~0.63.2",
    "@types/react-native-dotenv": "0.2.0",
    "@types/react-native-loading-spinner-overlay": "^0.5.2",
    "@types/react-native-vector-icons": "^6.4.6",
    "@types/react-test-renderer": "17.0.1",
    "babel-jest": "27.0.6",
    "babel-plugin-module-resolve": "0.0.2",
    "commitizen": "4.2.4",
    "cz-conventional-changelog": "3.3.0",
    "eas-cli": "0.24.1",
    "expo-cli": "4.11.0",
    "faker": "5.5.3",
    "husky": "^7.0.0",
    "jest": "27.0.6",
    "jest-expo": "^42.0.0",
    "react-test-renderer": "16.13.1",
    "semantic-release": "^17.4.7",
    "semantic-release-expo": "2.2.3",
    "ts-jest": "27.0.4",
    "typescript": "~4.0.0"
  },
  "private": true,
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "version": "0.0.0-development",
  "repository": {
    "type": "git",
    "url": "https://github.com/pnarielwala/choreo-cue.git"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "release": {
    "branches": [
      {
        "name": "main",
        "channel": "prod-v1"
      }
    ],
    "plugins": [
      "semantic-release-expo"
    ],
    "verifyConditions": [
      "semantic-release-expo",
      "@semantic-release/changelog",
      "@semantic-release/git"
    ],
    "prepare": [
      "semantic-release-expo",
      "@semantic-release/changelog",
      {
        "path": "@semantic-release/git",
        "assets": [
          "CHANGELOG.md",
          "app.json"
        ]
      },
      [
        "@semantic-release/exec",
        {
          "prepareCmd": "yarn expo login -u $EXPO_USERNAME -p $EXPO_PASSWORD"
        }
      ]
    ],
    "publish": [
      [
        "@semantic-release/exec",
        {
          "publishCmd": "yarn expo publish --release-channel ${options.channel}"
        }
      ]
    ]
  }
}
